<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo_principal">

    <!-- Cabecera fija -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/fondo_principal">

        <!-- Título de la máquina -->
        <TextView
            android:id="@+id/tituloMaquinaCheck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PUENTE GRÚA"
            android:textColor="@color/texto_blanco"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

    </LinearLayout>

    <!-- ProgressBar -->
    <ProgressBar
        android:id="@+id/progressBarCheck"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Contenido Scrollable (Items + Comentario + Botones de Acción) -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollViewItems"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Lista de ítems del checklist -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerItemsChecklist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

            <!-- Comentario General (visible solo si hay algún NO) -->
            <LinearLayout
                android:id="@+id/contenedorComentarioGeneral"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Descripción General del Problema*"
                    android:textColor="@color/texto_blanco"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/campoComentarioGeneral"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:hint="Describa los fallos detectados..."
                    android:textColorHint="#80FFFFFF"
                    android:textColor="@color/texto_blanco"
                    android:background="@drawable/fondo_campo_texto"
                    android:padding="12dp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:cursorVisible="true"
                    android:textCursorDrawable="@null" />



            </LinearLayout>

            <!-- Espaciador para empujar los botones al final si hay poco contenido -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Botones de acción al final del scroll -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Botón SIGUIENTE -->
                <Button
                    android:id="@+id/botonEnviarCheck"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/altura_boton_principal"
                    android:text="SIGUIENTE"
                    android:textColor="@color/texto_blanco"
                    android:textSize="@dimen/tamano_texto_boton"
                    android:textStyle="bold"
                    android:background="@drawable/fondo_boton_unificado"
                    android:backgroundTint="@color/boton_azul"
                    android:layout_marginBottom="12dp" />

                <!-- Botón MENU (Atrás) -->
                <Button
                    android:id="@+id/botonMenuCheck"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/altura_boton_principal"
                    android:text="MENU"
                    android:textColor="@color/texto_blanco"
                    android:textSize="@dimen/tamano_texto_boton"
                    android:textStyle="bold"
                    android:background="@drawable/fondo_boton_unificado"
                    android:backgroundTint="@color/boton_rojo"
                    android:layout_marginBottom="12dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
