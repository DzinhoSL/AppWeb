<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo_principal"
    android:padding="16dp">

    <!-- Fila superior: título + icono usuario -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tituloRegistro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REGISTRO"
            android:textColor="@color/texto_blanco"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_centerInParent="true" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentEnd="true"
            android:gravity="center_horizontal">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:tint="@color/texto_blanco" />

            <TextView
                android:id="@+id/inicialesUsuarioRegistro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="J.H"
                android:textColor="@color/texto_blanco"
                android:textSize="12sp" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Logo -->
    <ImageView
        android:id="@+id/logoRegistro"
        android:layout_width="160dp"
        android:layout_height="45dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/logo_psg"
        android:background="@android:color/transparent"
        android:padding="6dp"
        android:layout_marginBottom="8dp" />

    <!-- Fecha y hora -->
    <TextView
        android:id="@+id/textoFechaHoraRegistro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="19/03/26 - 8:03"
        android:textColor="@color/texto_blanco"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- ProgressBar -->
    <ProgressBar
        android:id="@+id/progressBarRegistro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Texto vacío -->
    <TextView
        android:id="@+id/textoVacioRegistro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/texto_blanco"
        android:gravity="center"
        android:textSize="16sp"
        android:visibility="gone" />

    <!-- Lista de máquinas con estado -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRegistro"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Botón Atrás -->
    <Button
        android:id="@+id/botonAtrasRegistro"
        android:layout_width="match_parent"
        android:layout_height="@dimen/altura_boton_principal"
        android:text="← ATRÁS"
        android:textColor="@color/texto_blanco"
        android:textSize="@dimen/tamano_texto_boton"
        android:textStyle="bold"
        android:background="@drawable/fondo_boton_unificado"
        android:backgroundTint="@color/boton_rojo"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

</LinearLayout>
