<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo_principal"
    android:padding="16dp">

    <!-- Título PANEL SANDWICH -->

    <!-- Logo -->
    <ImageView
        android:id="@+id/logoAlmacenes"
        android:layout_width="wrap_content"
        android:layout_height="113dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@android:color/transparent"
        android:padding="8dp"
        android:src="@drawable/logo_psg" />

    <!-- ProgressBar -->
    <ProgressBar
        android:id="@+id/progressBarAlmacenes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Texto de error -->
    <TextView
        android:id="@+id/textoErrorAlmacenes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/texto_blanco"
        android:gravity="center"
        android:textSize="16sp"
        android:visibility="gone" />

    <!-- Grid de almacenes -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAlmacenes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />


</LinearLayout>
