<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo_principal"
    android:padding="16dp">

    <!-- Título MAQUINARIA -->
    <TextView
        android:id="@+id/tituloMaquinaria"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MAQUINARIA"
        android:textColor="@color/texto_blanco"
        android:textSize="36sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="8dp" />

    <!-- Logo ampliado (similar a almacenes) -->
    <ImageView
        android:id="@+id/logoMaquinaria"
        android:layout_width="match_parent"
        android:layout_height="113dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/logo_psg"
        android:background="@android:color/transparent"
        android:padding="8dp"
        android:layout_marginBottom="24dp" />

    <!-- ProgressBar -->
    <ProgressBar
        android:id="@+id/progressBarMaquinaria"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Texto de error -->
    <TextView
        android:id="@+id/textoErrorMaquinaria"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/texto_blanco"
        android:gravity="center"
        android:textSize="16sp"
        android:visibility="gone" />

    <!-- Contenedor de botones de máquinas (se llenan dinámicamente) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/contenedorMaquinas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- Botón Atrás -->
    <Button
        android:id="@+id/botonAtrasMaquinaria"
        android:layout_width="match_parent"
        android:layout_height="@dimen/altura_boton_principal"
        android:text="← ATRÁS"
        android:textColor="@color/texto_blanco"
        android:textSize="@dimen/tamano_texto_boton"
        android:textStyle="bold"
        android:background="@drawable/fondo_boton_unificado"
        android:backgroundTint="@color/boton_rojo"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

</LinearLayout>
